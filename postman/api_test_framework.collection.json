      "name": "Favourites",
      "item": [
        {
          "name": "Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "  pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has image id\", function () {\r",
                  "  const body = pm.response.json();\r",
                  "  pm.expect(body).to.be.an(\"array\").that.is.not.empty;\r",
                  "  pm.expect(body[0]).to.have.property(\"id\");\r",
                  "  pm.environment.set(\"image_id\", body[0].id);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/images/search",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "images",
                "search"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Favourites",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Returns 200/201 for valid favourite\", function () {\r",
                  "  const code = pm.response.code;\r",
                  "  if (code === 401) {\r",
                  "    pm.expect.fail(\"Unauthorized: API key not injected correctly\");\r",
                  "  }\r",
                  "  pm.expect([200, 201]).to.include(code);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Saves favourite_id\", function () {\r",
                  "  const body = pm.response.json();\r",
                  "  pm.expect(body).to.have.property(\"id\");\r",
                  "  pm.environment.set(\"favourite_id\", body.id);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
