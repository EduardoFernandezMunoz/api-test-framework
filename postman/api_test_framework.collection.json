        {
          "name": "Favourites",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const favId = pm.environment.get(\"favourite_id\");\r",
                  "\r",
                  "pm.test(\"Should have a valid favourite_id\", function () {\r",
                  "  pm.expect(Number.isNaN(favId)).to.be.false;\r",
                  "  pm.expect(favId).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Deletes favourite (200/204)\", function () {\r",
                  "  if (pm.response.code === 401) {\r",
                  "    pm.expect.fail(\"Unauthorized: check API key\");\r",
                  "  }\r",
                  "  pm.expect([200, 204]).to.include(pm.response.code);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log(\"favourite_id:\", pm.environment.get(\"favourite_id\"));"
